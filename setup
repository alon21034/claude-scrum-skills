#!/usr/bin/env bash
# setup — install sprint skill and helper scripts

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

SKILL_ROOT="${SKILL_ROOT:-}"
COMMANDS_DIR="${COMMANDS_DIR:-}"
INSTALL_HOST="${SETUP_HOST:-auto}"
DRY_RUN=false

is_valid_host() {
  local host="$1"
  case "$host" in
    auto|claude|codex) return 0 ;;
    *) return 1 ;;
  esac
}

default_skill_root() {
  local host="${1:-auto}"
  case "$host" in
    codex)
      printf "%s\n" "$HOME/.codex/skills/sprint"
      ;;
    claude)
      printf "%s\n" "$HOME/.claude/skills/sprint"
      ;;
    auto)
      if [[ -d "$HOME/.codex/skills" ]]; then
        printf "%s\n" "$HOME/.codex/skills/sprint"
      elif [[ -d "$HOME/.claude/skills" ]]; then
        printf "%s\n" "$HOME/.claude/skills/sprint"
      else
        printf "%s\n" "$HOME/.codex/skills/sprint"
      fi
      ;;
  esac
}

default_commands_dir() {
  local host="${1:-auto}"
  case "$host" in
    codex)
      printf "%s\n" "$HOME/.codex/prompts"
      ;;
    claude)
      printf "%s\n" "$HOME/.claude/commands"
      ;;
    auto)
      if [[ -d "$HOME/.codex/prompts" ]]; then
        printf "%s\n" "$HOME/.codex/prompts"
        return
      fi
      if [[ -d "$HOME/.codex/commands" ]]; then
        printf "%s\n" "$HOME/.codex/commands"
        return
      fi
      if [[ -d "$HOME/.claude/commands" ]]; then
        printf "%s\n" "$HOME/.claude/commands"
        return
      fi
      printf "%s\n" "$HOME/.codex/prompts"
      ;;
  esac
}

usage() {
  cat <<'EOF'
Usage: ./setup [options]

Options:
  --host <auto|claude|codex>  Host to target for default paths (default: auto)
  --skill-root <path>    install root for sprint skill/bin (default: ~/.codex/skills/sprint, host-aware)
  --commands-dir <path>  slash-command directory (default: ~/.codex/prompts, fallback ~/.claude/commands)
  --dry-run              Print actions without writing files
  -h, --help             Show this help

Environment overrides:
  SETUP_HOST             same as --host
  SKILL_ROOT             same as --skill-root
  COMMANDS_DIR           same as --commands-dir
EOF
}

expand_path() {
  local path="$1"
  if [[ "$path" == "~/"* ]]; then
    printf "%s/%s\n" "$HOME" "${path#~/}"
  else
    printf "%s\n" "$path"
  fi
}

run() {
  if $DRY_RUN; then
    printf "[dry-run] %q" "$1"
    shift
    for arg in "$@"; do
      printf " %q" "$arg"
    done
    printf "\n"
    return 0
  fi
  "$@"
}

install_file() {
  local mode="$1"
  local src="$2"
  local dst="$3"

  if [[ -e "$dst" ]]; then
    local src_abs dst_abs
    src_abs="$(cd "$(dirname "$src")" && pwd -P)/$(basename "$src")"
    dst_abs="$(cd "$(dirname "$dst")" && pwd -P)/$(basename "$dst")"
    if [[ "$src_abs" == "$dst_abs" ]]; then
      return 0
    fi
  fi

  run install -m "$mode" "$src" "$dst"
}

link_skill_alias() {
  local alias_name="$1"
  local skills_parent skills_entry alias_path target_rel
  skills_parent="$(dirname "$SKILL_ROOT")"
  skills_entry="$(basename "$SKILL_ROOT")"
  alias_path="$skills_parent/$alias_name"
  target_rel="$skills_entry/$alias_name"

  if [[ -e "$alias_path" && ! -L "$alias_path" ]]; then
    echo "WARN: skipping alias $alias_path (exists and is not a symlink)" >&2
    return 0
  fi

  run ln -sfn "$target_rel" "$alias_path"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --host)
      [[ $# -ge 2 ]] || { echo "ERROR: --host requires a value" >&2; exit 1; }
      INSTALL_HOST="$2"
      if ! is_valid_host "$INSTALL_HOST"; then
        echo "ERROR: invalid --host value: $INSTALL_HOST (expected auto|claude|codex)" >&2
        exit 1
      fi
      shift 2
      ;;
    --skill-root)
      [[ $# -ge 2 ]] || { echo "ERROR: --skill-root requires a value" >&2; exit 1; }
      SKILL_ROOT="$2"
      shift 2
      ;;
    --commands-dir)
      [[ $# -ge 2 ]] || { echo "ERROR: --commands-dir requires a value" >&2; exit 1; }
      COMMANDS_DIR="$2"
      shift 2
      ;;
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      if [[ "$1" = "--g""stack-root" ]]; then
        echo "ERROR: --g""stack-root was removed. Use --skill-root instead." >&2
        exit 1
      fi
      echo "ERROR: unknown option: $1" >&2
      usage
      exit 1
      ;;
  esac
done

if ! is_valid_host "$INSTALL_HOST"; then
  echo "ERROR: invalid SETUP_HOST value: $INSTALL_HOST (expected auto|claude|codex)" >&2
  exit 1
fi

if [[ -z "$SKILL_ROOT" ]]; then
  SKILL_ROOT="$(default_skill_root "$INSTALL_HOST")"
fi
if [[ -z "$COMMANDS_DIR" ]]; then
  COMMANDS_DIR="$(default_commands_dir "$INSTALL_HOST")"
fi

SKILL_ROOT="$(expand_path "$SKILL_ROOT")"
COMMANDS_DIR="$(expand_path "$COMMANDS_DIR")"

REQUIRED_FILES=(
  "sprint/SKILL.md"
  "sprint/SKILL.md.tmpl"
  "sprint-task/SKILL.md"
  "sprint-board/SKILL.md"
  "sprint-finish/SKILL.md"
  "bin/sprint-setup"
  "bin/sprint-board"
  "bin/sprint-finish"
  "commands/sprint.md"
  "commands/sprint-task.md"
  "commands/sprint-board.md"
  "commands/sprint-finish.md"
)

for rel in "${REQUIRED_FILES[@]}"; do
  if [[ ! -f "$SCRIPT_DIR/$rel" ]]; then
    echo "ERROR: missing required file: $SCRIPT_DIR/$rel" >&2
    exit 1
  fi
done

run mkdir -p "$SKILL_ROOT/sprint" "$SKILL_ROOT/sprint-task" "$SKILL_ROOT/sprint-board" "$SKILL_ROOT/sprint-finish" "$SKILL_ROOT/bin" "$COMMANDS_DIR"

install_file 0644 "$SCRIPT_DIR/sprint/SKILL.md" "$SKILL_ROOT/sprint/SKILL.md"
install_file 0644 "$SCRIPT_DIR/sprint/SKILL.md.tmpl" "$SKILL_ROOT/sprint/SKILL.md.tmpl"
install_file 0644 "$SCRIPT_DIR/sprint-task/SKILL.md" "$SKILL_ROOT/sprint-task/SKILL.md"
install_file 0644 "$SCRIPT_DIR/sprint-board/SKILL.md" "$SKILL_ROOT/sprint-board/SKILL.md"
install_file 0644 "$SCRIPT_DIR/sprint-finish/SKILL.md" "$SKILL_ROOT/sprint-finish/SKILL.md"

install_file 0755 "$SCRIPT_DIR/bin/sprint-setup" "$SKILL_ROOT/bin/sprint-setup"
install_file 0755 "$SCRIPT_DIR/bin/sprint-board" "$SKILL_ROOT/bin/sprint-board"
install_file 0755 "$SCRIPT_DIR/bin/sprint-finish" "$SKILL_ROOT/bin/sprint-finish"

install_file 0644 "$SCRIPT_DIR/commands/sprint.md" "$COMMANDS_DIR/sprint.md"
install_file 0644 "$SCRIPT_DIR/commands/sprint-board.md" "$COMMANDS_DIR/sprint-board.md"
install_file 0644 "$SCRIPT_DIR/commands/sprint-finish.md" "$COMMANDS_DIR/sprint-finish.md"
install_file 0644 "$SCRIPT_DIR/commands/sprint-task.md" "$COMMANDS_DIR/sprint-task.md"

# Create top-level skill aliases so hosts that only scan one directory level
# can discover these as independent skills.
link_skill_alias "sprint-task"
link_skill_alias "sprint-board"
link_skill_alias "sprint-finish"

if $DRY_RUN; then
  echo "Dry run complete."
  exit 0
fi

cat <<EOF
Install complete.

Installed into:
  host mode:   $INSTALL_HOST
  skill root:  $SKILL_ROOT
  commands:    $COMMANDS_DIR

Quick checks:
  ls $SKILL_ROOT/bin/sprint-{setup,board,finish}
  ls $SKILL_ROOT/sprint/SKILL.md
  ls $SKILL_ROOT/sprint-{task,board,finish}/SKILL.md
  ls $(dirname "$SKILL_ROOT")/sprint-{task,board,finish}
  ls $COMMANDS_DIR/sprint{,-task,-board,-finish}.md
EOF
